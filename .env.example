# ===========================================
# Gestiora - Variables de Entorno
# ===========================================
# Copiar este archivo a .env y configurar los valores
# Las variables marcadas con [REQUERIDA] son obligatorias

# -------------------------------------------
# Servidor
# -------------------------------------------
NODE_ENV=development                # development | production | test
PORT=3000                           # Puerto del servidor

# -------------------------------------------
# Seguridad (JWT)
# -------------------------------------------
JWT_ACCESS_SECRET=change_me_access   # [REQUERIDA] Clave secreta para tokens de acceso
JWT_REFRESH_SECRET=change_me_refresh # [REQUERIDA] Clave secreta para tokens de refresco

# -------------------------------------------
# CORS y Documentacion
# -------------------------------------------
CORS=true                           # true | false | lista JSON de origenes | string
SWAGGER=true                        # true | false - Expone Swagger UI en /docs

# -------------------------------------------
# Base de Datos
# -------------------------------------------
DATABASE_TYPE=in-memory             # in-memory | postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname  # [REQUERIDA si DATABASE_TYPE=postgres]

# -------------------------------------------
# Almacenamiento de Archivos
# -------------------------------------------
STORAGE_TYPE=in-memory              # in-memory | local
STORAGE_PATH=storage                # Directorio para archivos (solo si STORAGE_TYPE=local)

# -------------------------------------------
# Inteligencia Artificial
# -------------------------------------------
AI_AGENT_TYPE=stub                  # stub | stub-error | genkit
OPENAI_API_KEY=openai_api_key_here  # [REQUERIDA si AI_AGENT_TYPE=genkit]
OAI_MODEL_NAME=                     # Modelo OpenAI: gpt-4.1 | gpt-4o | etc
PROVIDER_NAME=                      # Proveedor IA: OpenAI | Gemini (Google)
IA_TYPE=oai                         # oai | local | google

# -------------------------------------------
# RAG (Retrieval-Augmented Generation)
# -------------------------------------------
RAG_INDEX_NAME=                     # Nombre del indice para busquedas RAG
RAG_PROMPT_DIR=prompts              # Directorio de prompts (default: prompts)
RAG_EMBEDDER_MODEL=                 # Modelo de embeddings para RAG
