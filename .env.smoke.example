# =============================================================================
# Gestiora API Smoke Tests - Variables de Entorno
# =============================================================================
#
# Este archivo contiene las variables necesarias para ejecutar los smoke tests
# de la API de Gestiora.
#
# USO:
# 1. Copia este archivo a .env.smoke
# 2. Rellena los valores con credenciales validas
# 3. Asegurate de que el servidor este corriendo
# 4. Ejecuta: npm run api:smoke
#
# NOTA: Los valores por defecto corresponden a los usuarios de seed.
# Consulta AGENTS.md para mas informacion sobre datos de prueba.
# =============================================================================

# URL base del servidor (sin trailing slash)
BASE_URL=http://localhost:3000

# Credenciales del administrador (rol ADMIN)
# Usuario de seed: admin@example.com / AdminPass1!a
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass1!a

# Credenciales del usuario normal (rol USER)
# Usuario de seed: user@example.com / UserPass1!a01
USER_EMAIL=user@example.com
USER_PASSWORD=UserPass1!a01

# Password para el usuario de prueba creado durante el smoke test
# Debe cumplir requisitos de seguridad (min 12 chars, mayuscula, minuscula, numero, simbolo)
TEST_USER_PASSWORD=TestPass1!a1

# Delay entre peticiones en milisegundos (opcional)
# Util para evitar rate limiting o para debug visual
DELAY_MS=500
